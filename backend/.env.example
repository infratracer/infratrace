# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/infratrace?sslmode=require
DATABASE_URL_SYNC=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/infratrace?sslmode=require

# Auth
JWT_SECRET=your-random-64-char-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Blockchain (Polygon Amoy Testnet)
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
POLYGON_PRIVATE_KEY=your-testnet-wallet-private-key
CONTRACT_ADDRESS=your-deployed-contract-address
POLYGON_CHAIN_ID=80002

# AI (HuggingFace)
HF_API_TOKEN=hf_your-token-here
HF_MODEL_ID=yourusername/infratrace-analyser

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# App
ENVIRONMENT=development

# Seed Data (local dev defaults only — override in production)
SEED_ADMIN_PASSWORD=your-admin-password
SEED_DEMO_PASSWORD=your-demo-password
